{
  "name": "dotcloak",
  "version": "0.1.0",
  "description": "Encrypt your .env so AI coding tools can't read it",
  "type": "module",
  "bin": {
    "dotcloak": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "dotenv",
    "encryption",
    "secrets",
    "ai",
    "security",
    "age",
    "env",
    "environment-variables"
  ],
  "author": "3062-in-zamud",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3062-in-zamud/dotcloak.git"
  },
  "homepage": "https://github.com/3062-in-zamud/dotcloak",
  "bugs": {
    "url": "https://github.com/3062-in-zamud/dotcloak/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "files": ["dist/cli"],
  "dependencies": {
    "age-encryption": "^0.3.0",
    "commander": "^14.0.0",
    "smol-toml": "^1.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
